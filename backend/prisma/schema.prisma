// Prisma schema for Money Tracker - Escape from Consumer Society

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === USER & AUTH ===

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  name              String
  currency          String   @default("RUB")  // Основная валюта пользователя (ISO 4217)
  language          String   @default("en")   // Язык интерфейса
  hourlyRate        Int?     // Стоимость часа в копейках ОСНОВНОЙ валюты
  monthlyHours      Int?     @default(176) // Рабочих часов в месяц
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  accounts          Account[]
  transactions      Transaction[]
  categories        Category[]
  goals             Goal[]
  wishlist          WishlistItem[]
  gamification      UserGamification?
  achievements      UserAchievement[]
  xpEvents          XpEvent[]
  streakDays        StreakDay[]
  familyMember      FamilyMember?
  challenges        UserChallenge[]
  notifications     Notification[]
  deposits          Deposit[]
  loans             Loan[]
  savingsGoals      SavingsGoal[]
  forecastScenarios ForecastScenario[]
  chatMessages      ChatMessage[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

// === ACCOUNTS & TRANSACTIONS ===

model Account {
  id          String   @id @default(uuid())
  userId      String
  name        String
  type        AccountType
  balance     BigInt   @default(0)
  currency    String   @default("RUB")
  isDefault   Boolean  @default(false)
  includeInTotal Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

enum AccountType {
  CASH
  BANK
  CREDIT
  INVESTMENT
  DEBT
}

// === CATEGORIES ===

// Категории: системные (userId = NULL) и персональные (userId = user.id)
model Category {
  id               String   @id @default(uuid())
  userId           String?  // NULL = системная категория, UUID = персональная
  name             String
  type             CategoryType
  icon             String?
  color            String?
  isBaseNeed       Boolean  @default(false)
  excludeFromTotal Boolean  @default(false)
  monthlyLimit     BigInt?
  order            Int      @default(0)
  images           String[] // Массив URL картинок категории (для 1money-стиля)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@index([userId])
  @@map("categories")
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  accountId   String
  categoryId  String
  amount      BigInt
  type        TransactionType
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

// === GOALS ===
model Goal {
  id          String   @id @default(uuid())
  userId      String
  name        String
  targetAmount BigInt
  currentAmount BigInt  @default(0)
  currency    String   @default("RUB")
  deadline    DateTime @default(now())
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@map("goals")
}

model GoalContribution {
  id          String   @id @default(uuid())
  goalId      String
  amount      BigInt
  note        String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_contributions")
}

// === GAMIFICATION ===

model UserGamification {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  xp                      Int      @default(0)
  level                   Int      @default(1)
  savedAmount             BigInt   @default(0)
  status                  GamificationStatus @default(CONSUMER_DRONE)
  currentStreak           Int      @default(0)
  longestStreak           Int      @default(0)
  lastActionAt            DateTime?
  streakFreezeUsed        Boolean  @default(false)
  streakFreezeResetAt     DateTime?
  totalTransactions       Int      @default(0)
  totalRejected           Int      @default(0)
  totalPurchased          Int      @default(0)
  totalGoalsCompleted     Int      @default(0)
  consecutiveBudgetMonths Int      @default(0)
  hourlyRateSet           Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_gamification")
}

enum GamificationStatus {
  CONSUMER_DRONE
  AWAKENED
  ASCETIC
  STRATEGIST
  CAPITALIST
  FINANCIAL_ARCHITECT
}

model Achievement {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  description     String
  category        String
  iconUrl         String?
  xpReward        Int
  conditionType   AchievementCondition
  conditionValue  Json
  tier            AchievementTier @default(BRONZE)
  createdAt       DateTime @default(now())

  users           UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id              String   @id @default(uuid())
  userId          String
  achievementId   String
  earnedAt        DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

enum AchievementCondition {
  STREAK_DAYS
  WISHLIST_REJECTED
  BUDGET_UNDER_LIMIT
  TOTAL_TRANSACTIONS
  GOALS_COMPLETED
  TOTAL_SAVED_AMOUNT
  APP_USAGE_DAYS
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model XpEvent {
  id          String   @id @default(uuid())
  userId      String
  action      String
  baseXp      Int
  multiplier  Float    @default(1.0)
  totalXp     Int
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_events")
}

model StreakDay {
  id          String   @id @default(uuid())
  userId      String
  date        String
  actionCount Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("streak_days")
}

// === WISHLIST - Инкубатор желаний ===

model WishlistItem {
  id              String   @id @default(uuid())
  userId          String
  name            String
  price           BigInt
  description     String   @default("")
  imageUrl        String?
  category        String?
  status          WishlistStatus @default(PENDING)
  cooldownDays    Int      @default(7)
  createdAt       DateTime @default(now())
  cooldownEnds    DateTime
  decidedAt       DateTime?
  purchasedAt     DateTime?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wishlist_items")
}

enum WishlistStatus {
  PENDING
  READY
  REJECTED
  PURCHASED
  EXPIRED
}

// === CHALLENGES ===

model Challenge {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  description     String
  type            ChallengeType
  config          Json
  xpReward        Int
  iconUrl         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  users           UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id              String   @id @default(uuid())
  userId          String
  challengeId     String
  status          ChallengeStatus @default(ACTIVE)
  startDate       DateTime @default(now())
  endDate         DateTime
  progress        Json
  completedAt     DateTime?
  isWinner        Boolean?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge       Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId, startDate])
  @@map("user_challenges")
}

enum ChallengeType {
  PERSONAL
  FAMILY
  SOCIAL
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  FAILED
}

// === FAMILY ===

model Family {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  createdAt   DateTime @default(now())

  members     FamilyMember[]
}

model FamilyMember {
  id          String   @id @default(uuid())
  familyId    String
  userId      String   @unique
  role        FamilyRole @default(MEMBER)
  joinedAt    DateTime @default(now())

  family      Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@map("family_members")
}

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
}

// === NOTIFICATIONS ===

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  body        String
  data        Json?
  isRead      Boolean  @default(false)
  sentAt      DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  WISHLIST_READY
  BUDGET_ALERT
  CHALLENGE_INVITE
  LEVEL_UP
  ACHIEVEMENT_EARNED
  STREAK_WARNING
}

// === FINANCIAL FORECAST ===

model Deposit {
  id              String   @id @default(uuid())
  userId          String
  name            String
  type            DepositType
  principal       BigInt
  currentAmount   BigInt   @default(0)
  annualRate      Float
  compounding     CompoundingType
  termMonths      Int
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean  @default(true)
  autoRenew       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    DepositTransaction[]

  @@map("deposits")
}

enum DepositType {
  SAVINGS_ACCOUNT
  TERM_DEPOSIT
  INVESTMENT
  CRYPTO
  STOCKS
  BONDS
}

enum CompoundingType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  NONE
}

model DepositTransaction {
  id          String   @id @default(uuid())
  depositId   String
  amount      BigInt
  type        DepositTransactionType
  date        DateTime @default(now())
  description String?

  deposit     Deposit  @relation(fields: [depositId], references: [id], onDelete: Cascade)

  @@map("deposit_transactions")
}

enum DepositTransactionType {
  DEPOSIT
  WITHDRAWAL
  INTEREST
  TAX
  FEE
}

model Loan {
  id              String   @id @default(uuid())
  userId          String
  name            String
  type            LoanType
  principal       BigInt
  currentBalance  BigInt
  annualRate      Float
  termMonths      Int
  monthlyPayment  BigInt
  startDate       DateTime
  endDate         DateTime
  isPaidOff       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        LoanPayment[]

  @@map("loans")
}

enum LoanType {
  MORTGAGE
  CONSUMER
  AUTO
  STUDENT
  CREDIT_CARD
  MICROLOAN
}

model LoanPayment {
  id          String   @id @default(uuid())
  loanId      String
  amount      BigInt
  principal   BigInt
  interest    BigInt
  isPaid      Boolean  @default(false)
  dueDate     DateTime
  paidDate    DateTime?
  createdAt   DateTime @default(now())

  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_payments")
}

model SavingsGoal {
  id              String   @id @default(uuid())
  userId          String
  name            String
  targetAmount    BigInt
  currentAmount   BigInt   @default(0)
  monthlySave     BigInt
  startDate       DateTime
  targetDate      DateTime
  priority        Int      @default(0)
  isCompleted     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("savings_goals")
}

model ForecastScenario {
  id              String   @id @default(uuid())
  userId          String
  name            String
  description     String?
  
  // Параметры сценария
  monthlyIncome   BigInt
  monthlyExpenses BigInt
  monthlySave     BigInt
  
  // Вклады для симуляции
  deposits        Json
  
  // Кредиты для симуляции
  loans           Json
  
  // Параметры инфляции и доходности
  inflationRate   Float    @default(7.0)
  investmentReturnRate Float @default(10.0)
  
  forecastYears   Int      @default(10)
  
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("forecast_scenarios")
}

// === EXCHANGE RATES ===

enum CurrencyType {
  FIAT
  CRYPTO
  METAL
}

model ExchangeRate {
  id        String       @id @default(uuid())
  code      String       @unique  // USD, EUR, RUB, BTC, XAU etc.
  name      String                // "US Dollar", "Bitcoin", "Gold"
  symbol    String       @default("$")
  type      CurrencyType @default(FIAT)  // FIAT, CRYPTO, METAL
  popular   Boolean      @default(false) // Показывать в первой вкладке
  rate      Float                // Exchange rate: 1 USD = X of this currency
  source    String       @default("exchange-api")
  date      String                // YYYY-MM-DD from API response
  fetchedAt DateTime     @default(now())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("exchange_rates")
}

// === AI CHAT ===

model ChatMessage {
  id          String   @id @default(uuid())
  userId      String
  role        ChatRole
  content     String
  presetType  PresetType?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}

enum ChatRole {
  USER
  ASSISTANT
}

enum PresetType {
  SPENDING_REPORT
  BUDGET_ANALYSIS
  SAVINGS_TIPS
  DYNAMICS
}

// === TRANSLATIONS CACHE ===

model Translation {
  id        String   @id @default(uuid())
  language  String               // "en", "ru", "es"
  group     String               // "common", "auth", "home"
  key       String               // "login", "password"
  value     String               // "Log In", "Пароль"
  updatedAt DateTime @updatedAt

  @@unique([language, group, key])
  @@map("translations")
}
