generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === USER & AUTH ===

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  currency     String   @default("RUB")
  language     String   @default("en")
  hourlyRate   Int?
  monthlyHours Int?     @default(176)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts      Account[]
  transactions  Transaction[]
  categories    Category[]
  goals         Goal[]
  wishlist      WishlistItem[]
  familyMember  FamilyMember?
  notifications Notification[]
  chatMessages  ChatMessage[]
  subscription  Subscription?
  sessions      Session[]
  budgets       Budget[]
  recurringRules RecurringRule[]
  deposits      Deposit[]
  loans         Loan[]
  forecasts     ForecastScenario[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  deviceInfo   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// === ACCOUNTS & TRANSACTIONS ===

model Account {
  id             String      @id @default(uuid())
  userId         String
  name           String
  type           AccountType
  balance        BigInt      @default(0)
  currency       String      @default("RUB")
  isDefault      Boolean     @default(false)
  includeInTotal Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  recurringRules RecurringRule[]

  @@index([userId])
  @@map("accounts")
}

enum AccountType {
  CASH
  BANK
  CREDIT
  INVESTMENT
  DEBT
}

// === CATEGORIES ===

model Category {
  id               String       @id @default(uuid())
  userId           String?
  name             String
  type             CategoryType
  icon             String?
  color            String?
  isBaseNeed       Boolean      @default(false)
  excludeFromTotal Boolean      @default(false)
  monthlyLimit     BigInt?
  order            Int          @default(0)
  images           String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  recurringRules RecurringRule[]

  @@index([userId])
  @@map("categories")
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  accountId   String
  categoryId  String
  amount      BigInt
  type        TransactionType
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  recurringRuleId String?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  recurringRule RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([accountId])
  @@index([categoryId])
  @@index([recurringRuleId])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum RecurrencePeriod {
  WEEKLY
  MONTHLY
}

model RecurringRule {
  id          String           @id @default(uuid())
  userId      String
  accountId   String
  categoryId  String
  amount      BigInt
  type        TransactionType
  period      RecurrencePeriod
  dayOfWeek   Int?
  dayOfMonth  Int?
  description String?
  isActive    Boolean          @default(true)
  nextRunDate DateTime
  lastRunDate DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([nextRunDate])
  @@map("recurring_rules")
}

// === GOALS ===

model Goal {
  id            String   @id @default(uuid())
  userId        String
  name          String
  targetAmount  BigInt
  currentAmount BigInt   @default(0)
  currency      String   @default("RUB")
  deadline      DateTime @default(now())
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId])
  @@map("goals")
}

model GoalContribution {
  id        String   @id @default(uuid())
  goalId    String
  amount    BigInt
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_contributions")
}

// === WISHLIST ===

model WishlistItem {
  id           String         @id @default(uuid())
  userId       String
  name         String
  price        BigInt
  description  String         @default("")
  imageUrl     String?
  category     String?
  status       WishlistStatus @default(PENDING)
  cooldownDays Int            @default(7)
  createdAt    DateTime       @default(now())
  cooldownEnds DateTime
  decidedAt    DateTime?
  purchasedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("wishlist_items")
}

enum WishlistStatus {
  PENDING
  READY
  REJECTED
  PURCHASED
  EXPIRED
}

// === FAMILY ===

model Family {
  id         String         @id @default(uuid())
  name       String
  inviteCode String         @unique
  createdAt  DateTime       @default(now())

  members    FamilyMember[]
}

model FamilyMember {
  id             String      @id @default(uuid())
  familyId       String
  userId         String      @unique
  role           FamilyRole  @default(MEMBER)
  joinedAt       DateTime    @default(now())
  subscriptionId String?

  family       Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([familyId, userId])
  @@map("family_members")
}

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
}

// === NOTIFICATIONS ===

model Notification {
  id     String           @id @default(uuid())
  userId String
  type   NotificationType
  title  String
  body   String
  data   Json?
  isRead Boolean          @default(false)
  sentAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  WISHLIST_READY
  BUDGET_ALERT
  GOAL_COMPLETED
  MONTHLY_SUMMARY
}

// === BUDGETS ===

model Budget {
  id         String   @id @default(uuid())
  userId     String
  categoryId String
  amount     BigInt
  month      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month])
  @@index([userId, month])
  @@map("budgets")
}

// === EXCHANGE RATES ===

enum CurrencyType {
  FIAT
  CRYPTO
  METAL
}

model ExchangeRate {
  id        String       @id @default(uuid())
  code      String       @unique
  name      String
  symbol    String       @default("$")
  type      CurrencyType @default(FIAT)
  popular   Boolean      @default(false)
  rate      Float
  source    String       @default("exchange-api")
  date      String
  fetchedAt DateTime     @default(now())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("exchange_rates")
}

// === SUBSCRIPTION ===

enum SubscriptionPlan {
  FREE
  PREMIUM
  PREMIUM_FAMILY
}

model Subscription {
  id            String            @id @default(uuid())
  userId        String            @unique
  plan          SubscriptionPlan  @default(FREE)
  expiresAt     DateTime?
  startedAt     DateTime          @default(now())
  cancelledAt   DateTime?
  platform      String?
  transactionId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyMembers FamilyMember[]

  @@map("subscriptions")
}

// === AI CHAT ===

model ChatMessage {
  id         String     @id @default(uuid())
  userId     String
  role       ChatRole
  content    String
  presetType PresetType?
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}

enum ChatRole {
  USER
  ASSISTANT
}

enum PresetType {
  SPENDING_REPORT
  BUDGET_ANALYSIS
  SAVINGS_TIPS
  DYNAMICS
}

// === ARTICLES ===

model Article {
  id        String   @id @default(uuid())
  slug      String   @unique
  tag       String
  isPremium Boolean  @default(false)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations ArticleTranslation[]

  @@map("articles")
}

model ArticleTranslation {
  id        String   @id @default(uuid())
  articleId String
  language  String
  title     String
  content   String
  readTime  String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, language])
  @@map("article_translations")
}

// === TRANSLATIONS CACHE ===

model Translation {
  id        String   @id @default(uuid())
  language  String
  group     String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([language, group, key])
  @@map("translations")
}

// === DEPOSITS & LOANS ===

enum DepositType {
  SAVINGS_ACCOUNT
  TERM_DEPOSIT
  INVESTMENT
  BONDS
}

enum CompoundingType {
  DAILY
  MONTHLY
  QUARTERLY
  ANNUALLY
  NONE
}

model Deposit {
  id            String          @id @default(uuid())
  userId        String
  name          String
  type          DepositType
  principal     BigInt
  currentAmount BigInt
  annualRate    Float
  compounding   CompoundingType
  termMonths    Int
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions DepositTransaction[]

  @@index([userId])
  @@map("deposits")
}

model DepositTransaction {
  id          String                 @id @default(uuid())
  depositId   String
  amount      BigInt
  type        DepositTransactionType
  date        DateTime               @default(now())
  description String?
  createdAt   DateTime               @default(now())

  deposit Deposit @relation(fields: [depositId], references: [id], onDelete: Cascade)

  @@index([depositId])
  @@map("deposit_transactions")
}

enum DepositTransactionType {
  DEPOSIT
  WITHDRAWAL
  INTEREST
}

enum LoanType {
  MORTGAGE
  CONSUMER
  AUTO
  STUDENT
  CREDIT_CARD
}

model Loan {
  id             String   @id @default(uuid())
  userId         String
  name           String
  type           LoanType
  principal      BigInt
  currentBalance BigInt
  annualRate     Float
  termMonths     Int
  monthlyPayment BigInt
  startDate      DateTime
  endDate        DateTime?
  isPaidOff      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments LoanPayment[]

  @@index([userId])
  @@map("loans")
}

model LoanPayment {
  id        String   @id @default(uuid())
  loanId    String
  amount    BigInt
  principal BigInt
  interest  BigInt
  isPaid    Boolean  @default(false)
  dueDate   DateTime
  paidDate  DateTime?
  createdAt DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("loan_payments")
}

// === FORECAST ===

model ForecastScenario {
  id                  String   @id @default(uuid())
  userId              String
  name                String
  description         String?
  monthlyIncome       BigInt
  monthlyExpenses     BigInt
  monthlySave         BigInt
  deposits            Json     @default("[]")
  loans               Json     @default("[]")
  inflationRate       Float    @default(7.0)
  investmentReturnRate Float   @default(10.0)
  forecastYears       Int      @default(10)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("forecast_scenarios")
}
