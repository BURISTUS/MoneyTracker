{
  "expo": {
    "name": "Money Tracker",
    "slug": "money-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "scheme": "moneytracker",
    "newArchEnabled": true,
    "android": {
      "jsEngine": "jsc",
      "adaptiveIcon": {
        "backgroundColor": "#007AFF"
      },
      "package": "com.escape.moneytracker",
      "permissions": ["RECEIVE_NOTIFICATIONS"]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.escape.moneytracker",
      "infoPlist": {
        "CFBundleDisplayName": "Money Tracker"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-splash-screen"
    ]
  }
}
